// ── HUD ───────────────────────────────────────────────────────────
function updateLives() {
  const bar = document.getElementById('lives');
  bar.innerHTML = '';
  for(let i=0;i<maxCourage;i++){
    const l=document.createElement('span'); l.className='lv';
    l.textContent = i<courage ? '💛' : '🖤';
    bar.appendChild(l);
  }
}

// ── TYPE WRITER ───────────────────────────────────────────────────
function typeText(text, cb) {
  clearInterval(typeTimer); typing=true; tapReady=false;
  const el=document.getElementById('dialogue'); el.textContent=''; let i=0;
  typeTimer=setInterval(()=>{
    el.textContent+=text[i++];
    if(i>=text.length){ clearInterval(typeTimer); typing=false; tapReady=true; if(cb) cb(); }
  }, 24);
}

function showStep(idx) {
  if(idx==='end'){ showEnding(); return; }
  const step=STORY[idx]; if(!step){ showEnding(); return; }
  storyIdx=idx; scene=step.scene;
  const tb=document.getElementById('textbox'); tb.style.display='block';
  document.getElementById('speaker').textContent=step.spk;
  document.getElementById('choices').innerHTML='';
  document.getElementById('tap-hint').style.display='none';
  tapReady=false;
  typeText(step.txt, ()=>{
    if(step.choices){
      const ch=document.getElementById('choices');
      step.choices.forEach(c=>{
        const btn=document.createElement('button'); btn.className='choice'; btn.textContent=c.txt;
        btn.onclick=()=>{
          courage=Math.max(1,Math.min(maxCourage,courage+(c.c||0)));
          updateLives();
          document.getElementById('choices').innerHTML='';
          showStep(c.next);
        };
        ch.appendChild(btn);
      });
    } else {
      document.getElementById('tap-hint').style.display='block';
    }
  });
}

document.getElementById('textbox').addEventListener('click', ()=>{
  if(typing){
    clearInterval(typeTimer); typing=false; tapReady=true;
    document.getElementById('dialogue').textContent=STORY[storyIdx].txt;
    if(!STORY[storyIdx].choices) document.getElementById('tap-hint').style.display='block';
    return;
  }
  if(tapReady && !STORY[storyIdx].choices){
    tapReady=false; document.getElementById('tap-hint').style.display='none';
    showStep(STORY[storyIdx].next);
  }
});

// ── ENDING ────────────────────────────────────────────────────────
function showEnding() {
  document.getElementById('ending').classList.add('show');
  const letters = [
`Djeque,

Desde a escola primária até hoje —
23 anos de vida, de histórias, de Maputo.

Atravessámos um rio cheio de DRILOCOCOS
só para ir a uma festa. Isso diz tudo.

Que os 23 sejam grandes como tu és —
calmo por fora, cheio de força por dentro.

JAGA DA BOA NACE e feliz aniversário! 🎂🔥

Com muito respeito e amizade,
— Edson`,
`Djeque,

23 anos e ainda aqui —
os dois de Maputo, os dois de pé.

Não sei se os DRILOCOCOS existiam mesmo
mas sei que a nossa amizade existe de verdade.

Feliz aniversário, irmão. 🎂

— Edson`,
  ];
  const idx = courage>=4?0:1;
  document.getElementById('end-card').textContent = letters[idx];
  document.getElementById('end-courage').textContent = 'Coragem desbloqueada: '+courage+' / '+maxCourage+' 💛';
}

function restart() {
  courage=3; storyIdx=0; scene='maputo';
  document.getElementById('ending').classList.remove('show');
  document.getElementById('textbox').style.display='none';
  document.getElementById('choices').innerHTML='';
  document.getElementById('splash').style.display='flex';
  updateLives();
}

// ── START ─────────────────────────────────────────────────────────
document.getElementById('sp-btn').onclick=()=>{
  document.getElementById('splash').style.display='none';
  updateLives(); showStep(0);
};

function drawScene(s) {
  ctx.clearRect(0,0,W,H);
  if(s==='maputo')  drawMaputo();
  else if(s==='rio') drawRio();
  else if(s==='party') drawParty();
  else if(s==='future') drawFuture();
}

updateLives();
(function loop(){ frameT++; drawScene(scene); requestAnimationFrame(loop); })();
</script>
